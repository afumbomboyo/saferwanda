
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information, selected security services, and hardware onboarding progress.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Firebase Auth ID" },
        "fullName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email" },
        "isAdmin": { "type": "boolean", "description": "Flag for platform administrators." },
        "servicesSelected": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of SafeRwanda service IDs user has opted into."
        },
        "isOnboarded": { "type": "boolean", "description": "Flag indicating if user finished initial setup." },
        "purchaseStatus": { 
          "type": "string", 
          "enum": ["none", "purchased", "leased"],
          "description": "Hardware procurement status."
        },
        "hasPaidSetupFee": { "type": "boolean", "description": "Whether the user opted for professional installation." },
        "deviceId": { "type": "string", "description": "The linked IoT hardware unique identifier." },
        "deviceName": { "type": "string", "description": "User-assigned name for the device." },
        "alertPhone": { "type": "string", "description": "Phone number for distress alerts." },
        "alertEmail": { "type": "string", "description": "Email address for distress alerts." },
        "subscriptionActive": { "type": "boolean", "description": "Whether the service subscription is current." },
        "subscriptionType": { 
          "type": "string", 
          "enum": ["none", "weekly", "monthly", "yearly"] 
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "isOnboarded"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "User profile document containing account settings, hardware status, and chosen services."
    }
  }
}
